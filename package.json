{
  "name": "mangia-metaframework",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrian-ub/mangia.git"
  },
  "bugs": "https://github.com/adrian-ub/mangia/issues",
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepare": "git config core.hooksPath .githooks && simple-git-hooks"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "eslint": "^10.5.0",
    "nano-staged": "^1.0.2",
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run lint:fix"
  },
  "nano-staged": {
    "*": "eslint --fix"
  }
}
